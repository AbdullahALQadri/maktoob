<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Maktoob</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>Maktoob</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<!-- Camera Permission -->
		<key>NSCameraUsageDescription</key>
		<string>يحتاج التطبيق إلى الوصول إلى الكاميرا لالتقاط الصور ومسح رموز QR</string>
		<!-- Contacts Permission -->
		<key>NSContactsUsageDescription</key>
		<string>يحتاج التطبيق إلى الوصول إلى جهات الاتصال لدعوة الأصدقاء والعائلة</string>
		<!-- Photo Library Permissions -->
		<key>NSPhotoLibraryUsageDescription</key>
		<string>يحتاج التطبيق إلى الوصول إلى مكتبة الصور لاختيار وتحميل الصور</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>يحتاج التطبيق إلى إذن لحفظ الصور في مكتبة الصور</string>
		<!-- Location Permissions -->
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>يحتاج التطبيق إلى موقعك لعرض الأماكن القريبة والخرائط</string>
		<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
		<string>يحتاج التطبيق إلى موقعك لتتبع الموقع وإرسال التنبيهات</string>
		<key>NSLocationAlwaysUsageDescription</key>
		<string>يحتاج التطبيق إلى موقعك في الخلفية لإرسال التنبيهات المستندة إلى الموقع</string>
		<!-- Microphone Permission -->
		<key>NSMicrophoneUsageDescription</key>
		<string>يحتاج التطبيق إلى الوصول إلى الميكروفون لتسجيل الصوت</string>
		<!-- Calendar Permission -->
		<key>NSCalendarsUsageDescription</key>
		<string>يحتاج التطبيق إلى الوصول إلى التقويم لإضافة الأحداث والمناسبات</string>
		<!-- Bluetooth Permission -->
		<key>NSBluetoothAlwaysUsageDescription</key>
		<string>يحتاج التطبيق إلى البلوتوث للاتصال بالأجهزة القريبة</string>
		<key>NSBluetoothPeripheralUsageDescription</key>
		<string>يحتاج التطبيق إلى البلوتوث للاتصال بالأجهزة الطرفية</string>
		<!-- Motion/Sensors Permission -->
		<key>NSMotionUsageDescription</key>
		<string>يحتاج التطبيق إلى الوصول إلى مستشعرات الحركة</string>
		<!-- Face ID Permission -->
		<key>NSFaceIDUsageDescription</key>
		<string>يحتاج التطبيق إلى Face ID للمصادقة الآمنة</string>
		<key>UIStatusBarHidden</key>
		<false/>
	</dict>
</plist>
